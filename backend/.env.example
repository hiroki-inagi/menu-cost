DATABASE_URL=postgresql://user:password@localhost:5432/menucost
SECRET_KEY=your-secret-key-here-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key-here

# --- パスワード再設定メール（SMTP）---
# Gmailを使う場合: 2段階認証を有効にし「アプリパスワード」を発行してSMTP_PASSWORDに設定
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-address@gmail.com
SMTP_FROM_NAME=MenuCost
SMTP_USE_TLS=true
# 再設定リンクの生成に使うフロントエンドのURL（本番では公開URLに変更）
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_EXPIRE_MINUTES=60
